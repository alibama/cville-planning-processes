<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             id="Definitions_ApprovalSelector"
             name="Cville Dev Code - Approval Process Selector"
             namespace="https://lexipedia.xyz/cville/dev-code">
  <inputData id="Input_ActionType" name="Project Action"><variable id="Var_ActionType" name="actionType" typeRef="string" /></inputData>
  <inputData id="Input_Overlay" name="Overlay / Property Status"><variable id="Var_Overlay" name="overlay" typeRef="string" /></inputData>
  <inputData id="Input_UsePermission" name="Use Permission in District"><variable id="Var_UsePermission" name="usePermission" typeRef="string" /></inputData>
  <inputData id="Input_DimensionalRelief" name="Dimensional Relief Sought"><variable id="Var_DimensionalRelief" name="dimensionalReliefSought" typeRef="boolean" /></inputData>
  <inputData id="Input_Floodplain" name="In Floodplain"><variable id="Var_Floodplain" name="inFloodplain" typeRef="boolean" /></inputData>
  <inputData id="Input_CriticalSlopes" name="Critical Slopes Impacted"><variable id="Var_CriticalSlopes" name="criticalSlopesImpacted" typeRef="boolean" /></inputData>

  <decision id="Decision_RequiredProcesses" name="Required Approval Process(es)">
    <question>Given the project's attributes, which Div. 5.2 / Art. 6 approval process(es) apply?</question>
    <informationRequirement id="IR_AT"><requiredInput href="#Input_ActionType" /></informationRequirement>
    <informationRequirement id="IR_OV"><requiredInput href="#Input_Overlay" /></informationRequirement>
    <informationRequirement id="IR_UP"><requiredInput href="#Input_UsePermission" /></informationRequirement>
    <informationRequirement id="IR_DR"><requiredInput href="#Input_DimensionalRelief" /></informationRequirement>
    <informationRequirement id="IR_FP"><requiredInput href="#Input_Floodplain" /></informationRequirement>
    <informationRequirement id="IR_CS"><requiredInput href="#Input_CriticalSlopes" /></informationRequirement>
    <decisionTable id="Table_RequiredProcesses" hitPolicy="COLLECT" outputLabel="Required Process">
      <input id="In_AT" label="Project Action"><inputExpression id="InExpr_AT" typeRef="string"><text>actionType</text></inputExpression></input>
      <input id="In_OV" label="Overlay / Property Status"><inputExpression id="InExpr_OV" typeRef="string"><text>overlay</text></inputExpression></input>
      <input id="In_UP" label="Use Permission"><inputExpression id="InExpr_UP" typeRef="string"><text>usePermission</text></inputExpression></input>
      <input id="In_DR" label="Dimensional Relief"><inputExpression id="InExpr_DR" typeRef="boolean"><text>dimensionalReliefSought</text></inputExpression></input>
      <input id="In_FP" label="Floodplain"><inputExpression id="InExpr_FP" typeRef="boolean"><text>inFloodplain</text></inputExpression></input>
      <input id="In_CS" label="Critical Slopes"><inputExpression id="InExpr_CS" typeRef="boolean"><text>criticalSlopesImpacted</text></inputExpression></input>
      <output id="Out_Proc" label="Required Process" name="requiredProcess" typeRef="string" />
      <rule id="r1"><inputEntry id="r1_at"><text>"Rezone"</text></inputEntry><inputEntry id="r1_ov"><text>-</text></inputEntry><inputEntry id="r1_up"><text>-</text></inputEntry><inputEntry id="r1_dr"><text>-</text></inputEntry><inputEntry id="r1_fp"><text>-</text></inputEntry><inputEntry id="r1_cs"><text>-</text></inputEntry><outputEntry id="r1_o"><text>"5.2.5 Zoning Map Amendment (Rezoning)"</text></outputEntry></rule>
      <rule id="r2"><inputEntry id="r2_at"><text>"ZoningTextAmendment"</text></inputEntry><inputEntry id="r2_ov"><text>-</text></inputEntry><inputEntry id="r2_up"><text>-</text></inputEntry><inputEntry id="r2_dr"><text>-</text></inputEntry><inputEntry id="r2_fp"><text>-</text></inputEntry><inputEntry id="r2_cs"><text>-</text></inputEntry><outputEntry id="r2_o"><text>"5.2.5 Zoning Text Amendment"</text></outputEntry></rule>
      <rule id="r3"><inputEntry id="r3_at"><text>"ComprehensivePlanAmendment"</text></inputEntry><inputEntry id="r3_ov"><text>-</text></inputEntry><inputEntry id="r3_up"><text>-</text></inputEntry><inputEntry id="r3_dr"><text>-</text></inputEntry><inputEntry id="r3_fp"><text>-</text></inputEntry><inputEntry id="r3_cs"><text>-</text></inputEntry><outputEntry id="r3_o"><text>"5.2.3 Comprehensive Plan Amendment"</text></outputEntry></rule>
      <rule id="r4"><inputEntry id="r4_at"><text>"ReviewOfPublicFacilities"</text></inputEntry><inputEntry id="r4_ov"><text>-</text></inputEntry><inputEntry id="r4_up"><text>-</text></inputEntry><inputEntry id="r4_dr"><text>-</text></inputEntry><inputEntry id="r4_fp"><text>-</text></inputEntry><inputEntry id="r4_cs"><text>-</text></inputEntry><outputEntry id="r4_o"><text>"5.2.4 Review of Public Facilities"</text></outputEntry></rule>
      <rule id="r5"><inputEntry id="r5_at"><text>"NewDevelopment"</text></inputEntry><inputEntry id="r5_ov"><text>-</text></inputEntry><inputEntry id="r5_up"><text>-</text></inputEntry><inputEntry id="r5_dr"><text>-</text></inputEntry><inputEntry id="r5_fp"><text>-</text></inputEntry><inputEntry id="r5_cs"><text>-</text></inputEntry><outputEntry id="r5_o"><text>"5.2.9 Development Review"</text></outputEntry></rule>
      <rule id="r6"><inputEntry id="r6_at"><text>"Subdivision"</text></inputEntry><inputEntry id="r6_ov"><text>-</text></inputEntry><inputEntry id="r6_up"><text>-</text></inputEntry><inputEntry id="r6_dr"><text>-</text></inputEntry><inputEntry id="r6_fp"><text>-</text></inputEntry><inputEntry id="r6_cs"><text>-</text></inputEntry><outputEntry id="r6_o"><text>"6.7 Subdivision Review (Div. 6.7)"</text></outputEntry></rule>
      <rule id="r7"><inputEntry id="r7_at"><text>"Sign"</text></inputEntry><inputEntry id="r7_ov"><text>"None"</text></inputEntry><inputEntry id="r7_up"><text>-</text></inputEntry><inputEntry id="r7_dr"><text>-</text></inputEntry><inputEntry id="r7_fp"><text>-</text></inputEntry><inputEntry id="r7_cs"><text>-</text></inputEntry><outputEntry id="r7_o"><text>"5.2.10 Sign Permit (Permit Review)"</text></outputEntry></rule>
      <rule id="r8"><inputEntry id="r8_at"><text>"TemporaryUse"</text></inputEntry><inputEntry id="r8_ov"><text>-</text></inputEntry><inputEntry id="r8_up"><text>-</text></inputEntry><inputEntry id="r8_dr"><text>-</text></inputEntry><inputEntry id="r8_fp"><text>-</text></inputEntry><inputEntry id="r8_cs"><text>-</text></inputEntry><outputEntry id="r8_o"><text>"5.2.10 Temporary Use Permit (Permit Review)"</text></outputEntry></rule>
      <rule id="r9"><inputEntry id="r9_at"><text>"TreeRemoval"</text></inputEntry><inputEntry id="r9_ov"><text>-</text></inputEntry><inputEntry id="r9_up"><text>-</text></inputEntry><inputEntry id="r9_dr"><text>-</text></inputEntry><inputEntry id="r9_fp"><text>-</text></inputEntry><inputEntry id="r9_cs"><text>-</text></inputEntry><outputEntry id="r9_o"><text>"5.2.10 Tree Removal Permit (Permit Review)"</text></outputEntry></rule>
      <rule id="r10"><inputEntry id="r10_at"><text>-</text></inputEntry><inputEntry id="r10_ov"><text>-</text></inputEntry><inputEntry id="r10_up"><text>"SpecialUse"</text></inputEntry><inputEntry id="r10_dr"><text>-</text></inputEntry><inputEntry id="r10_fp"><text>-</text></inputEntry><inputEntry id="r10_cs"><text>-</text></inputEntry><outputEntry id="r10_o"><text>"5.2.14 Special Use Permit"</text></outputEntry></rule>
      <rule id="r11"><inputEntry id="r11_at"><text>-</text></inputEntry><inputEntry id="r11_ov"><text>-</text></inputEntry><inputEntry id="r11_up"><text>"NotPermitted"</text></inputEntry><inputEntry id="r11_dr"><text>-</text></inputEntry><inputEntry id="r11_fp"><text>-</text></inputEntry><inputEntry id="r11_cs"><text>-</text></inputEntry><outputEntry id="r11_o"><text>"Use prohibited - rezoning (5.2.5) or redesign required"</text></outputEntry></rule>
      <rule id="r12"><inputEntry id="r12_at"><text>-</text></inputEntry><inputEntry id="r12_ov"><text>-</text></inputEntry><inputEntry id="r12_up"><text>-</text></inputEntry><inputEntry id="r12_dr"><text>True</text></inputEntry><inputEntry id="r12_fp"><text>False</text></inputEntry><inputEntry id="r12_cs"><text>-</text></inputEntry><outputEntry id="r12_o"><text>"5.2.12 Variance (BZA)"</text></outputEntry></rule>
      <rule id="r13"><inputEntry id="r13_at"><text>-</text></inputEntry><inputEntry id="r13_ov"><text>-</text></inputEntry><inputEntry id="r13_up"><text>-</text></inputEntry><inputEntry id="r13_dr"><text>True</text></inputEntry><inputEntry id="r13_fp"><text>True</text></inputEntry><inputEntry id="r13_cs"><text>-</text></inputEntry><outputEntry id="r13_o"><text>"5.2.13 Floodplain Variance (BZA)"</text></outputEntry></rule>
      <rule id="r14"><inputEntry id="r14_at"><text>-</text></inputEntry><inputEntry id="r14_ov"><text>-</text></inputEntry><inputEntry id="r14_up"><text>-</text></inputEntry><inputEntry id="r14_dr"><text>-</text></inputEntry><inputEntry id="r14_fp"><text>True</text></inputEntry><inputEntry id="r14_cs"><text>-</text></inputEntry><outputEntry id="r14_o"><text>"5.2.10 Floodplain Permit (Permit Review)"</text></outputEntry></rule>
      <rule id="r15"><inputEntry id="r15_at"><text>-</text></inputEntry><inputEntry id="r15_ov"><text>-</text></inputEntry><inputEntry id="r15_up"><text>-</text></inputEntry><inputEntry id="r15_dr"><text>-</text></inputEntry><inputEntry id="r15_fp"><text>-</text></inputEntry><inputEntry id="r15_cs"><text>True</text></inputEntry><outputEntry id="r15_o"><text>"5.2.16 Critical Slopes Special Exception"</text></outputEntry></rule>
      <rule id="r16a"><inputEntry id="r16a_at"><text>"BuildingOrExteriorAlteration"</text></inputEntry><inputEntry id="r16a_ov"><text>"ADC"</text></inputEntry><inputEntry id="r16a_up"><text>-</text></inputEntry><inputEntry id="r16a_dr"><text>-</text></inputEntry><inputEntry id="r16a_fp"><text>-</text></inputEntry><inputEntry id="r16a_cs"><text>-</text></inputEntry><outputEntry id="r16a_o"><text>"5.2.6 Minor or 5.2.7 Major Historic Review (CoA, per scope)"</text></outputEntry></rule>
      <rule id="r16b"><inputEntry id="r16b_at"><text>"BuildingOrExteriorAlteration"</text></inputEntry><inputEntry id="r16b_ov"><text>"HC"</text></inputEntry><inputEntry id="r16b_up"><text>-</text></inputEntry><inputEntry id="r16b_dr"><text>-</text></inputEntry><inputEntry id="r16b_fp"><text>-</text></inputEntry><inputEntry id="r16b_cs"><text>-</text></inputEntry><outputEntry id="r16b_o"><text>"5.2.6 Minor or 5.2.7 Major Historic Review (CoA, per scope)"</text></outputEntry></rule>
      <rule id="r16c"><inputEntry id="r16c_at"><text>"Sign"</text></inputEntry><inputEntry id="r16c_ov"><text>"ADC"</text></inputEntry><inputEntry id="r16c_up"><text>-</text></inputEntry><inputEntry id="r16c_dr"><text>-</text></inputEntry><inputEntry id="r16c_fp"><text>-</text></inputEntry><inputEntry id="r16c_cs"><text>-</text></inputEntry><outputEntry id="r16c_o"><text>"5.2.6 Minor or 5.2.7 Major Historic Review (CoA, in lieu of Sign Permit)"</text></outputEntry></rule>
      <rule id="r16d"><inputEntry id="r16d_at"><text>"Sign"</text></inputEntry><inputEntry id="r16d_ov"><text>"HC"</text></inputEntry><inputEntry id="r16d_up"><text>-</text></inputEntry><inputEntry id="r16d_dr"><text>-</text></inputEntry><inputEntry id="r16d_fp"><text>-</text></inputEntry><inputEntry id="r16d_cs"><text>-</text></inputEntry><outputEntry id="r16d_o"><text>"5.2.6 Minor or 5.2.7 Major Historic Review (CoA, in lieu of Sign Permit)"</text></outputEntry></rule>
      <rule id="r17a"><inputEntry id="r17a_at"><text>"BuildingOrExteriorAlteration"</text></inputEntry><inputEntry id="r17a_ov"><text>"IndividuallyProtected"</text></inputEntry><inputEntry id="r17a_up"><text>-</text></inputEntry><inputEntry id="r17a_dr"><text>-</text></inputEntry><inputEntry id="r17a_fp"><text>-</text></inputEntry><inputEntry id="r17a_cs"><text>-</text></inputEntry><outputEntry id="r17a_o"><text>"5.2.7 Major Historic Review (CoA)"</text></outputEntry></rule>
      <rule id="r17b"><inputEntry id="r17b_at"><text>"Sign"</text></inputEntry><inputEntry id="r17b_ov"><text>"IndividuallyProtected"</text></inputEntry><inputEntry id="r17b_up"><text>-</text></inputEntry><inputEntry id="r17b_dr"><text>-</text></inputEntry><inputEntry id="r17b_fp"><text>-</text></inputEntry><inputEntry id="r17b_cs"><text>-</text></inputEntry><outputEntry id="r17b_o"><text>"5.2.7 Major Historic Review (CoA)"</text></outputEntry></rule>
      <rule id="r18a"><inputEntry id="r18a_at"><text>"BuildingOrExteriorAlteration"</text></inputEntry><inputEntry id="r18a_ov"><text>"EntranceCorridor"</text></inputEntry><inputEntry id="r18a_up"><text>-</text></inputEntry><inputEntry id="r18a_dr"><text>-</text></inputEntry><inputEntry id="r18a_fp"><text>-</text></inputEntry><inputEntry id="r18a_cs"><text>-</text></inputEntry><outputEntry id="r18a_o"><text>"5.2.8 Corridor Review (CoA)"</text></outputEntry></rule>
      <rule id="r18b"><inputEntry id="r18b_at"><text>"Sign"</text></inputEntry><inputEntry id="r18b_ov"><text>"EntranceCorridor"</text></inputEntry><inputEntry id="r18b_up"><text>-</text></inputEntry><inputEntry id="r18b_dr"><text>-</text></inputEntry><inputEntry id="r18b_fp"><text>-</text></inputEntry><inputEntry id="r18b_cs"><text>-</text></inputEntry><outputEntry id="r18b_o"><text>"5.2.8 Corridor Review (CoA)"</text></outputEntry></rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_Selector">
    <dmndi:DMNShape id="S_Dec" dmnElementRef="Decision_RequiredProcesses"><dc:Bounds x="380" y="80" width="220" height="80" /></dmndi:DMNShape>
    <dmndi:DMNShape id="S_AT" dmnElementRef="Input_ActionType"><dc:Bounds x="40" y="280" width="150" height="60" /></dmndi:DMNShape>
    <dmndi:DMNShape id="S_OV" dmnElementRef="Input_Overlay"><dc:Bounds x="210" y="280" width="150" height="60" /></dmndi:DMNShape>
    <dmndi:DMNShape id="S_UP" dmnElementRef="Input_UsePermission"><dc:Bounds x="380" y="280" width="150" height="60" /></dmndi:DMNShape>
    <dmndi:DMNShape id="S_DR" dmnElementRef="Input_DimensionalRelief"><dc:Bounds x="550" y="280" width="150" height="60" /></dmndi:DMNShape>
    <dmndi:DMNShape id="S_FP" dmnElementRef="Input_Floodplain"><dc:Bounds x="720" y="280" width="150" height="60" /></dmndi:DMNShape>
    <dmndi:DMNShape id="S_CS" dmnElementRef="Input_CriticalSlopes"><dc:Bounds x="890" y="280" width="150" height="60" /></dmndi:DMNShape>
    <dmndi:DMNEdge id="E_AT" dmnElementRef="IR_AT"><di:waypoint x="115" y="280" /><di:waypoint x="440" y="160" /></dmndi:DMNEdge>
    <dmndi:DMNEdge id="E_OV" dmnElementRef="IR_OV"><di:waypoint x="285" y="280" /><di:waypoint x="465" y="160" /></dmndi:DMNEdge>
    <dmndi:DMNEdge id="E_UP" dmnElementRef="IR_UP"><di:waypoint x="455" y="280" /><di:waypoint x="490" y="160" /></dmndi:DMNEdge>
    <dmndi:DMNEdge id="E_DR" dmnElementRef="IR_DR"><di:waypoint x="625" y="280" /><di:waypoint x="515" y="160" /></dmndi:DMNEdge>
    <dmndi:DMNEdge id="E_FP" dmnElementRef="IR_FP"><di:waypoint x="795" y="280" /><di:waypoint x="540" y="160" /></dmndi:DMNEdge>
    <dmndi:DMNEdge id="E_CS" dmnElementRef="IR_CS"><di:waypoint x="965" y="280" /><di:waypoint x="560" y="160" /></dmndi:DMNEdge>
  </dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
