        <dc:Bounds x="2085" y="320" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Gateway_HasProffers" bpmnElement="Gateway_HasProffers" isMarkerVisible="true">
        <dc:Bounds x="2345" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Task_FinalProffer" bpmnElement="Task_FinalProffer">
        <dc:Bounds x="2505" y="170" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Task_Transmit" bpmnElement="Task_Transmit">
