        <di:waypoint x="78" y="360" />
        <di:waypoint x="245" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f2" bpmnElement="f2">
        <di:waypoint x="295" y="360" />
        <di:waypoint x="405" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f3" bpmnElement="f3">
        <di:waypoint x="295" y="360" />
        <di:waypoint x="610" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f4" bpmnElement="f4">
        <di:waypoint x="555" y="210" />
        <di:waypoint x="610" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f5" bpmnElement="f5">
        <di:waypoint x="770" y="360" />
        <di:waypoint x="825" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f6" bpmnElement="f6">
        <di:waypoint x="975" y="360" />
        <di:waypoint x="1085" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f7" bpmnElement="f7">
        <di:waypoint x="1135" y="360" />
        <di:waypoint x="1245" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f8" bpmnElement="f8">
        <di:waypoint x="1135" y="360" />
        <di:waypoint x="1455" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f9" bpmnElement="f9">
        <di:waypoint x="1395" y="210" />
        <di:waypoint x="1455" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f10" bpmnElement="f10">
        <di:waypoint x="1605" y="360" />
        <di:waypoint x="1665" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f11" bpmnElement="f11">
        <di:waypoint x="1815" y="360" />
        <di:waypoint x="1925" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f12" bpmnElement="f12">
        <di:waypoint x="1975" y="360" />
        <di:waypoint x="2085" y="510" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f13" bpmnElement="f13">
        <di:waypoint x="1975" y="360" />
        <di:waypoint x="2085" y="360" />
      </bpmndi:BPMNEdge>
