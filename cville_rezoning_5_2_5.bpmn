      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Gateway_Modif" bpmnElement="Gateway_Modif" isMarkerVisible="true">
        <dc:Bounds x="3185" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Task_AddlHearing" bpmnElement="Task_AddlHearing">
        <dc:Bounds x="3345" y="470" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Task_ReferPC" bpmnElement="Task_ReferPC">
        <dc:Bounds x="3345" y="620" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Gateway_CouncilAction" bpmnElement="Gateway_CouncilAction" isMarkerVisible="true">
